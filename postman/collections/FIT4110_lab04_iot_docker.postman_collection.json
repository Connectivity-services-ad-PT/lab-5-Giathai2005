{
  "openapi": "3.0.0",
  "info": {
    "title": "FIT4110_lab05_iot_docker.postman_collection.json.",
    "version": "1.0.0",
    "description": "Contract dùng cho Lab 05 Docker Compose readiness, kế thừa logic của Lab 03/04.\nPayload chính dùng các trường device_id, metric, value, unit và timestamp.\nBoundary minh hoạ cho temperature là -40 đến 80.\n"
  },
  "servers": [
    {
      "url": "http://localhost:8000"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Kiểm tra trạng thái service",
        "responses": {
          "200": {
            "description": "Service đang hoạt động",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "service": {
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "ok",
                  "service": "iot-ingestion",
                  "version": "0.5.0"
                }
              }
            }
          }
        },
        "tags": [
          "health"
        ],
        "description": "Public health check dùng để kiểm tra container hoặc mock server đã sẵn sàng."
      }
    },
    "/readings/latest": {
      "get": {
        "summary": "Lấy các bản ghi cảm biến mới nhất",
        "parameters": [
          {
            "name": "device_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "example": "ESP32-LAB-A01"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "example": 5
          }
        ],
        "responses": {
          "200": {
            "description": "Danh sách bản ghi mới nhất",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "reading_id": {
                            "type": "string"
                          },
                          "device_id": {
                            "type": "string"
                          },
                          "metric": {
                            "type": "string"
                          },
                          "value": {
                            "type": "number"
                          },
                          "unit": {
                            "type": "string"
                          },
                          "timestamp": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "created_at": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "items": [
                    {
                      "reading_id": "R-20260513-0001",
                      "device_id": "ESP32-LAB-A01",
                      "metric": "temperature",
                      "value": 31.5,
                      "unit": "celsius",
                      "timestamp": "2026-05-13T08:30:00+07:00",
                      "created_at": "2026-05-13T08:30:01+07:00"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Thiếu hoặc sai token",
            "content": {
              "application/problem+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "format": "uri"
                    },
                    "title": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    },
                    "detail": {
                      "type": "string"
                    },
                    "instance": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "type": "https://smart-campus.local/problems/validation-error",
                  "title": "Validation error",
                  "status": 422,
                  "detail": "body.value must be less than or equal to 80",
                  "instance": "/readings"
                }
              }
            }
          },
          "422": {
            "description": "Query parameter không hợp lệ",
            "content": {
              "application/problem+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "format": "uri"
                    },
                    "title": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    },
                    "detail": {
                      "type": "string"
                    },
                    "instance": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "type": "https://smart-campus.local/problems/validation-error",
                  "title": "Validation error",
                  "status": 422,
                  "detail": "body.value must be less than or equal to 80",
                  "instance": "/readings"
                }
              }
            }
          }
        },
        "tags": [
          "readings",
          "latest"
        ],
        "description": "Trả về danh sách bản ghi mới nhất, có thể lọc theo thiết bị và giới hạn số dòng."
      }
    },
    "/readings/{reading_id}": {
      "get": {
        "summary": "Lấy chi tiết một bản ghi cảm biến",
        "responses": {
          "200": {
            "description": "Chi tiết bản ghi cảm biến",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "reading_id": {
                      "type": "string"
                    },
                    "device_id": {
                      "type": "string"
                    },
                    "metric": {
                      "type": "string"
                    },
                    "value": {
                      "type": "number"
                    },
                    "unit": {
                      "type": "string"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "created_at": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                },
                "example": {
                  "reading_id": "R-20260513-0001",
                  "device_id": "ESP32-LAB-A01",
                  "metric": "temperature",
                  "value": 31.5,
                  "unit": "celsius",
                  "timestamp": "2026-05-13T08:30:00+07:00",
                  "created_at": "2026-05-13T08:30:01+07:00"
                }
              }
            }
          },
          "401": {
            "description": "Thiếu hoặc sai token",
            "content": {
              "application/problem+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "format": "uri"
                    },
                    "title": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    },
                    "detail": {
                      "type": "string"
                    },
                    "instance": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "type": "https://smart-campus.local/problems/validation-error",
                  "title": "Validation error",
                  "status": 422,
                  "detail": "body.value must be less than or equal to 80",
                  "instance": "/readings"
                }
              }
            }
          },
          "404": {
            "description": "Không tìm thấy bản ghi",
            "content": {
              "application/problem+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "format": "uri"
                    },
                    "title": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    },
                    "detail": {
                      "type": "string"
                    },
                    "instance": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "type": "https://smart-campus.local/problems/not-found",
                  "title": "Not Found",
                  "status": 404,
                  "detail": "Reading R-20260513-9999 does not exist",
                  "instance": "/readings/R-20260513-9999"
                }
              }
            }
          }
        },
        "tags": [
          "readings",
          "{reading_id}"
        ]
      },
      "parameters": [
        {
          "name": "reading_id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          },
          "example": "R-20260513-0001"
        }
      ]
    },
    "/readings": {
      "post": {
        "summary": "Gửi một bản ghi cảm biến từ thiết bị IoT",
        "responses": {
          "201": {
            "description": "Đã ghi nhận bản đọc cảm biến",
            "headers": {
              "X-Warning": {
                "description": "Warning trả về khi reading được chấp nhận nhưng có rủi ro, ví dụ nhiệt độ cao.",
                "schema": {
                  "type": "string"
                },
                "example": "string"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "reading_id": {
                      "type": "string"
                    },
                    "device_id": {
                      "type": "string"
                    },
                    "metric": {
                      "type": "string"
                    },
                    "accepted": {
                      "type": "boolean"
                    },
                    "created_at": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                },
                "example": {
                  "reading_id": "R-20260513-0001",
                  "device_id": "ESP32-LAB-A01",
                  "metric": "temperature",
                  "accepted": true,
                  "created_at": "2026-05-13T08:30:01+07:00"
                }
              }
            }
          },
          "401": {
            "description": "Thiếu hoặc sai token",
            "content": {
              "application/problem+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "format": "uri"
                    },
                    "title": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    },
                    "detail": {
                      "type": "string"
                    },
                    "instance": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "type": "https://smart-campus.local/problems/unauthorized",
                  "title": "Unauthorized",
                  "status": 401,
                  "detail": "Missing or invalid bearer token",
                  "instance": "/readings"
                }
              }
            }
          },
          "422": {
            "description": "Request không hợp lệ",
            "content": {
              "application/problem+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "format": "uri"
                    },
                    "title": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    },
                    "detail": {
                      "type": "string"
                    },
                    "instance": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "type": "https://smart-campus.local/problems/validation-error",
                  "title": "Validation error",
                  "status": 422,
                  "detail": "body.value must be less than or equal to 80",
                  "instance": "/readings"
                }
              }
            }
          },
          "429": {
            "description": "Thiết bị gửi dữ liệu quá nhiều trong thời gian ngắn",
            "content": {
              "application/problem+json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "format": "uri"
                    },
                    "title": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    },
                    "detail": {
                      "type": "string"
                    },
                    "instance": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "type": "https://smart-campus.local/problems/validation-error",
                  "title": "Validation error",
                  "status": 422,
                  "detail": "body.value must be less than or equal to 80",
                  "instance": "/readings"
                }
              }
            }
          }
        },
        "tags": [
          "readings"
        ],
        "description": "Endpoint nhận telemetry từ ESP32 hoặc gateway.\nRequest phải có device_id, metric, value và timestamp.\nTrong lab này, ví dụ boundary dùng nhiệt độ hợp lệ từ -40 đến 80.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "device_id": {
                    "type": "string"
                  },
                  "metric": {
                    "type": "string"
                  },
                  "value": {
                    "type": "number"
                  },
                  "unit": {
                    "type": "string"
                  },
                  "timestamp": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              },
              "example": {
                "device_id": "ESP32-LAB-A01",
                "metric": "temperature",
                "value": 31.5,
                "unit": "celsius",
                "timestamp": "2026-05-13T08:30:00+07:00"
              }
            }
          }
        }
      }
    }
  },
